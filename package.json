{
  "name": "voice-scribe",
  "displayName": "Voice Scribe",
  "description": "High-quality real-time voice-to-text for VS Code with live rewriting",
  "version": "0.1.3",
  "publisher": "1vecera",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "voice",
    "dictation",
    "speech-to-text",
    "transcription",
    "ai",
    "scribe"
  ],
  "activationEvents": [
    "onCommand:voiceScribe.startRecording",
    "onCommand:voiceScribe.toggleRecording",
    "onCommand:voiceScribe.configureApiKey",
    "onCommand:voiceScribe.selectLanguage"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voiceScribe.startRecording",
        "title": "Voice Scribe: Start Recording"
      },
      {
        "command": "voiceScribe.stopRecording",
        "title": "Voice Scribe: Stop Recording"
      },
      {
        "command": "voiceScribe.configureApiKey",
        "title": "Voice Scribe: Configure API Key"
      },
      {
        "command": "voiceScribe.selectLanguage",
        "title": "Voice Scribe: Select Language"
      },
      {
        "command": "voiceScribe.toggleRecording",
        "title": "Voice Scribe: Toggle Recording"
      }
    ],
    "configuration": {
      "title": "Voice Scribe",
      "properties": {
        "voiceScribe.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your ElevenLabs API key for speech-to-text"
        },
        "voiceScribe.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh",
            "es",
            "hi",
            "pt",
            "ru",
            "ja",
            "de",
            "fr",
            "it",
            "ko",
            "nl",
            "pl",
            "sv",
            "tr",
            "cs",
            "da",
            "fi",
            "el",
            "hu",
            "no",
            "ro",
            "sk",
            "uk",
            "bg",
            "hr",
            "ca",
            "ta",
            "ar",
            "ms",
            "id",
            "th",
            "vi",
            "tl"
          ],
          "enumDescriptions": [
            "Auto-detect (let the API detect the spoken language)",
            "English",
            "Chinese",
            "Spanish",
            "Hindi",
            "Portuguese",
            "Russian",
            "Japanese",
            "German",
            "French",
            "Italian",
            "Korean",
            "Dutch",
            "Polish",
            "Swedish",
            "Turkish",
            "Czech",
            "Danish",
            "Finnish",
            "Greek",
            "Hungarian",
            "Norwegian",
            "Romanian",
            "Slovak",
            "Ukrainian",
            "Bulgarian",
            "Croatian",
            "Catalan",
            "Tamil",
            "Arabic",
            "Malay",
            "Indonesian",
            "Thai",
            "Vietnamese",
            "Filipino"
          ],
          "description": "Language you are speaking in for transcription (ISO 639-1 code). Set to 'auto' to let the API detect your language automatically."
        }
      }
    },
    "keybindings": [
      {
        "command": "voiceScribe.toggleRecording",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "mocha 'out/test/**/*.test.js' --timeout 10000"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "mocha": "^10.7.0",
    "proxyquire": "^2.1.3",
    "sinon": "^17.0.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "ws": "^8.14.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1vecera/vscode-voice-scribe.git"
  },
  "homepage": "https://github.com/1vecera/vscode-voice-scribe#readme",
  "bugs": {
    "url": "https://github.com/1vecera/vscode-voice-scribe/issues"
  },
  "author": {
    "name": "1vecera",
    "url": "https://github.com/1vecera"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "license": "MIT"
}
