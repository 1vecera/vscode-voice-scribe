{
  "name": "voice-scribe",
  "displayName": "Voice Scribe",
  "description": "High-quality real-time voice-to-text for VS Code with live rewriting",
  "version": "0.3.1",
  "publisher": "1vecera",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "voice",
    "dictation",
    "speech-to-text",
    "transcription",
    "ai",
    "scribe"
  ],
  "activationEvents": [
    "onCommand:voiceScribe.toggleRecording",
    "onCommand:voiceScribe.configureApiKey",
    "onCommand:voiceScribe.selectLanguage",
    "onCommand:voiceScribe.setRecordingPrefix"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voiceScribe.configureApiKey",
        "title": "Voice Scribe: Configure API Key"
      },
      {
        "command": "voiceScribe.selectLanguage",
        "title": "Voice Scribe: Select Language"
      },
      {
        "command": "voiceScribe.toggleRecording",
        "title": "Voice Scribe: Toggle Recording"
      },
      {
        "command": "voiceScribe.setRecordingPrefix",
        "title": "Voice Scribe: Set Recording Prefix"
      }
    ],
    "configuration": {
      "title": "Voice Scribe",
      "properties": {
        "voiceScribe.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your ElevenLabs API key for speech-to-text"
        },
        "voiceScribe.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh",
            "es",
            "hi",
            "pt",
            "ru",
            "ja",
            "de",
            "fr",
            "it",
            "ko",
            "nl",
            "pl",
            "sv",
            "tr",
            "cs",
            "da",
            "fi",
            "el",
            "hu",
            "no",
            "ro",
            "sk",
            "uk",
            "bg",
            "hr",
            "ca",
            "ta",
            "ar",
            "ms",
            "id",
            "th",
            "vi",
            "tl"
          ],
          "enumDescriptions": [
            "Auto-detect (let the API detect the spoken language)",
            "English",
            "Chinese",
            "Spanish",
            "Hindi",
            "Portuguese",
            "Russian",
            "Japanese",
            "German",
            "French",
            "Italian",
            "Korean",
            "Dutch",
            "Polish",
            "Swedish",
            "Turkish",
            "Czech",
            "Danish",
            "Finnish",
            "Greek",
            "Hungarian",
            "Norwegian",
            "Romanian",
            "Slovak",
            "Ukrainian",
            "Bulgarian",
            "Croatian",
            "Catalan",
            "Tamil",
            "Arabic",
            "Malay",
            "Indonesian",
            "Thai",
            "Vietnamese",
            "Filipino"
          ],
          "description": "Language you are speaking in for transcription (ISO 639-1 code). Set to 'auto' to let the API detect your language automatically."
        },
        "voiceScribe.insertMode": {
          "type": "string",
          "default": "smart",
          "enum": [
            "plain",
            "comment",
            "smart"
          ],
          "enumDescriptions": [
            "Insert transcribed text as-is",
            "Always wrap committed text in a line comment",
            "Auto-comment in code files, plain text in prose files (markdown, plaintext, etc.)"
          ],
          "description": "How committed transcriptions are inserted into the editor."
        },
        "voiceScribe.removeFiller": {
          "type": "boolean",
          "default": true,
          "description": "Remove filler words (um, uh, like, you know, etc.) from transcriptions."
        },
        "voiceScribe.enableVoiceCommands": {
          "type": "boolean",
          "default": true,
          "description": "Enable voice commands (undo, redo, delete line, save, stop, etc.). When enabled, spoken commands are executed instead of inserted as text."
        },
        "voiceScribe.target": {
          "type": "string",
          "default": "editor",
          "enum": [
            "editor",
            "terminal"
          ],
          "enumDescriptions": [
            "Insert committed text into the active text editor (default)",
            "Send committed text to the integrated terminal"
          ],
          "description": "Where committed transcriptions are sent."
        },
        "voiceScribe.vadSensitivity": {
          "type": "string",
          "default": "medium",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "enumDescriptions": [
            "Noisy environment (open office, cafe). Rejects more non-speech.",
            "Normal room (default)",
            "Quiet room or headset. More sensitive to speech."
          ],
          "description": "Voice Activity Detection sensitivity preset. Controls how aggressively non-speech audio is rejected."
        },
        "voiceScribe.customVocabulary": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "word": {
                "type": "string",
                "description": "The word or phrase to boost recognition for"
              },
              "boost": {
                "type": "number",
                "description": "Boost factor (1.0-10.0). Higher values increase recognition likelihood."
              },
              "phonemes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional phoneme hints for pronunciation"
              }
            },
            "required": [
              "word"
            ]
          },
          "description": "Custom vocabulary for improved recognition of domain-specific terms. Max 200 entries. Each entry requires a 'word' and optionally 'boost' (1.0-10.0) and 'phonemes'."
        },
        "voiceScribe.noiseReduction": {
          "type": "string",
          "default": "neural",
          "enum": [
            "off",
            "basic",
            "neural"
          ],
          "enumDescriptions": [
            "No audio filters — raw microphone input sent directly",
            "Basic filters: highpass, lowpass, and FFT-based denoising (default)",
            "Enhanced: basic filters plus RNNoise neural noise suppression (downloads a small model on first use)"
          ],
          "description": "Audio noise reduction level applied before sending audio to the speech recognition API."
        },
        "voiceScribe.recordingPrefix": {
          "type": "string",
          "default": "",
          "description": "Custom string inserted at the cursor when recording starts (e.g. '// '). Set via the 'Voice Scribe: Set Recording Prefix' command."
        },
        "voiceScribe.autoVocabulary": {
          "type": "boolean",
          "default": true,
          "description": "Automatically extract identifiers from open files and boost them in the speech recognition vocabulary."
        }
      }
    },
    "keybindings": [
      {
        "command": "voiceScribe.toggleRecording",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "mocha 'out/test/**/*.test.js' --timeout 10000"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "mocha": "^10.7.0",
    "proxyquire": "^2.1.3",
    "sinon": "^17.0.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "ws": "^8.14.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1vecera/vscode-voice-scribe.git"
  },
  "homepage": "https://github.com/1vecera/vscode-voice-scribe#readme",
  "bugs": {
    "url": "https://github.com/1vecera/vscode-voice-scribe/issues"
  },
  "author": {
    "name": "1vecera",
    "url": "https://github.com/1vecera"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "license": "MIT"
}
